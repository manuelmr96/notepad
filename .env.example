# Notepad backend environment configuration.
#
# Copy this file to `.env` (which is gitignored) and fill in real values.
# SECRET_KEY MUST be a strong random value, e.g. `openssl rand -hex 32`.
# Never commit real secrets — config is read entirely from the environment.

# Async SQLAlchemy connection string (asyncpg driver).
DATABASE_URL=postgresql+asyncpg://notepad:notepad@postgres:5432/notepad

# JWT signing key. Generate with: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# Token lifetimes.
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

# Comma-separated allowed origins for split-domain deploys.
# Leave empty for same-origin (default, behind a reverse proxy) — no CORS middleware.
CORS_ORIGINS=

# Set false only for local non-HTTPS development.
COOKIE_SECURE=true
