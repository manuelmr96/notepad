# Notepad stack environment configuration.
#
# Copy this file to `.env` (which is gitignored) and fill in real values:
#   cp .env.example .env
# `docker compose up` reads this file (env_file: .env) for the backend service.
# SECRET_KEY MUST be a strong random value, e.g. `openssl rand -hex 32`.
# Never commit real secrets — config is read entirely from the environment.

# Async SQLAlchemy connection string (asyncpg driver).
# Under Compose the backend connects to the `postgres` service over the compose
# network; docker-compose.yml pins this host, so this value is the canonical
# in-container URL. For host-side tooling, use localhost + a published port.
DATABASE_URL=postgresql+asyncpg://notepad:notepad@postgres:5432/notepad

# Optional dedicated database for the test suite. When running
# `docker compose exec backend pytest`, point this at a SEPARATE database so the
# session-scoped create_all/drop_all harness never touches app data. If unset,
# the tests fall back to DATABASE_URL.
# TEST_DATABASE_URL=postgresql+asyncpg://notepad:notepad@postgres:5432/notepad_test

# JWT signing key. Generate with: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# Token lifetimes.
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

# Comma-separated allowed origins for split-domain deploys.
# Leave empty for same-origin (default, behind a reverse proxy) — no CORS middleware.
CORS_ORIGINS=

# Refresh-cookie Secure flag. Set false ONLY for local non-HTTPS development
# (the dev stack is served over plain HTTP on localhost). MUST be true in
# production, where TLS terminates at the reverse proxy.
COOKIE_SECURE=false

# Path scope for the refresh-token cookie. MUST be a prefix of the public refresh
# path as the BROWSER sees it. The SPA reaches the API same-origin under the
# `/api` proxy mount (Vite dev proxy + nginx), so it calls POST /api/auth/refresh.
# Per RFC 6265 the browser only sends the cookie on paths under this value — it
# MUST cover /api/auth (not the bare /auth, which the browser never requests).
# Change this only if you change the public API proxy prefix.
COOKIE_PATH=/api/auth
